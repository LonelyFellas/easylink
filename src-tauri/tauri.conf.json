{
  "version": "1.1.6",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "Easy Link",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources"],
    "publisher": "Easy Link",
    "externalBin": ["sidecar/verge-mihomo", "sidecar/verge-mihomo-alpha"],
    "copyright": "Copyright © 2026 EasyLink",
    "category": "DeveloperTool",
    "shortDescription": "Easy Link",
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://localhost:3000/",
    "removeUnusedCommands": true
  },
  "productName": "EasyLink",
  "identifier": "io.github.lonelyfellas.easylink",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDRTdFNTgxN0RENjhBMEEKUldRS2l0WjlnZVhuSEVGdFloU1hlbnlGcEt2LzJmZ050UTFtZ3ozQVpjYTVxVE1laGRRQWFCZVUK",
      "endpoints": [
        "https://gitee.com/yu-shengming/elinkpc/releases/download/updater/update.json",
        "https://gh-proxy.org/https://github.com/LonelyFellas/easylink/releases/download/updater/update-proxy.json",
        "https://update.hwdns.net/https://github.com/LonelyFellas/easylink/releases/download/updater/update-proxy.json",
        "https://github.com/LonelyFellas/easylink/releases/download/updater/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": ["easylink"]
      }
    }
  },
  "app": {
    "security": {
      "capabilities": ["desktop-capability", "migrated"],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  }
}
